{
  "kind": "collectionType",
  "collectionName": "rsvps",
  "info": {
    "singularName": "rsvp",
    "pluralName": "rsvps",
    "displayName": "RSVP",
    "description": "Tədbir qeydiyyatları (RSVP) — yalnız təsdiqlənmiş kimliklərdən (F2.6e)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": false
    }
  },
  "attributes": {
    "eventSlug": {
      "type": "string",
      "required": true
    },
    "eventTitle": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "going",
        "maybe",
        "declined"
      ],
      "default": "going"
    },
    "guests": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "note": {
      "type": "text"
    },
    "verified": {
      "type": "boolean",
      "default": false
    },
    "identity": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::identity.identity",
      "inversedBy": "rsvps"
    }
  }
}
